# Gemini API Key for LLM OCR functionality (used when OCR_BACKEND=gemini)
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── OCR Backend ───────────────────────────────────────────────────────────────
# "gemini"          → Google Gemini 2.5 Flash Lite (default, cloud, per-token cost)
# "deepseek_modal"  → DeepSeek OCR 2 on Modal serverless GPU (pay-per-second)
OCR_BACKEND=gemini

# ── Modal / DeepSeek OCR settings ────────────────────────────────────────────
# Required when OCR_BACKEND=deepseek_modal.
#
# 1. Deploy the Modal app:   modal deploy modal_app/deepseek_ocr.py
# 2. Copy the endpoint URL printed by Modal and set it below.
# 3. Get your Token ID and Secret from https://modal.com/settings/tokens
#
MODAL_OCR_ENDPOINT=https://deepseek-ocr-service--deepseekocr-extract.modal.run
MODAL_TOKEN_ID=your_modal_token_id
MODAL_TOKEN_SECRET=your_modal_token_secret
# Page render resolution sent to DeepSeek (higher = better quality, slower upload)
MODAL_OCR_DPI=150
# Per-page HTTP timeout in seconds (GPU cold starts can take ~15s)
MODAL_OCR_TIMEOUT=120
# Max concurrent requests to Modal (lower = less GPU cost, higher = faster batch)
MODAL_OCR_CONCURRENT_REQUESTS=5

# ── Google Cloud Storage – direct browser upload bypass ──────────────────────
# Enables large-file uploads that skip Cloudflare's 100 MB proxy limit.
# Files go: Browser → GCS (signed URL) → your server → local uploads/ dir.
#
# 1. Create a GCS bucket in the Cloud Console.
# 2. Create a Service Account with  roles/storage.objectAdmin  on that bucket.
# 3. Download the service-account JSON key and set GCS_CREDENTIALS_FILE below.
# 4. Configure CORS on the bucket (see README – GCS Setup section).
# 5. Set GCS_BUCKET_NAME and restart the app.
#
# Leave GCS_BUCKET_NAME empty to fall back to the old multipart upload path.

GCS_BUCKET_NAME=your-bucket-name
GCS_CREDENTIALS_FILE=/path/to/service-account-key.json
# How long the browser has to begin the PUT before the signed URL expires:
GCS_SIGNED_URL_EXPIRY_MINUTES=15
# Delete the temp GCS object once the server has pulled it locally:
GCS_DELETE_AFTER_DOWNLOAD=true