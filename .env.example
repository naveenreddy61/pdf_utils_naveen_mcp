# Gemini API Key for LLM OCR functionality
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Cloud Storage – direct browser upload bypass ──────────────────────
# Enables large-file uploads that skip Cloudflare's 100 MB proxy limit.
# Files go: Browser → GCS (signed URL) → your server → local uploads/ dir.
#
# 1. Create a GCS bucket in the Cloud Console.
# 2. Create a Service Account with  roles/storage.objectAdmin  on that bucket.
# 3. Download the service-account JSON key and set GCS_CREDENTIALS_FILE below.
# 4. Configure CORS on the bucket (see README – GCS Setup section).
# 5. Set GCS_BUCKET_NAME and restart the app.
#
# Leave GCS_BUCKET_NAME empty to fall back to the old multipart upload path.

GCS_BUCKET_NAME=your-bucket-name
GCS_CREDENTIALS_FILE=/path/to/service-account-key.json
# How long the browser has to begin the PUT before the signed URL expires:
GCS_SIGNED_URL_EXPIRY_MINUTES=15
# Delete the temp GCS object once the server has pulled it locally:
GCS_DELETE_AFTER_DOWNLOAD=true

# ── Modal OCR backend (serverless GPU) ───────────────────────────────────────
# Alternative OCR backend that runs an open-weights model on a Modal GPU.
# The web app exposes a Gemini / Modal radio on the OCR form — leave these
# vars empty to hide the Modal option / have it error.
#
# Setup:
#   1. Sign up at modal.com, install the CLI:  uv run modal setup
#   2. (optional) Change model/GPU:
#        export OCR_MODAL_MODEL_ID=deepseek-ai/DeepSeek-OCR-2
#        export OCR_MODAL_GPU=L40S          # L40S | A100 | H100 | B200 …
#   3. Deploy the Modal app:
#        uv run modal deploy modal_app/ocr_app.py
#   4. Copy the printed endpoint URL into OCR_MODAL_ENDPOINT below.
#   5. (optional) For web-endpoint auth create tokens at
#        https://modal.com/settings/tokens  and set the pair below.

OCR_MODAL_APP_NAME=pdf-ocr-modal
OCR_MODAL_MODEL_ID=deepseek-ai/DeepSeek-OCR-2
OCR_MODAL_GPU=L40S
OCR_MODAL_ENDPOINT=
OCR_MODAL_TOKEN_ID=
OCR_MODAL_TOKEN_SECRET=
# Page render resolution sent to the GPU (higher = better quality, slower upload)
OCR_MODAL_DPI=150
# Per-page HTTP timeout in seconds (first cold start after a deploy can take 1–2 min)
OCR_MODAL_TIMEOUT=180
# Max concurrent requests against Modal (lower = less GPU cost, higher = faster batch)
OCR_MODAL_CONCURRENT_REQUESTS=5